@startuml
' Use case diagram for H2O Chimal
left to right direction
skinparam packageStyle rect

actor Citizen as C
actor Operator as O
actor Administrator as A

package "User Actions" {
  usecase "Register / Login" as UC1
  usecase "Report Leak" as UC2
  usecase "View My Reports" as UC3
  usecase "Cancel Report" as UC4
  usecase "Rate Service" as UC5
}

package "Service & Documents" {
  usecase "View Services Catalog" as UC6
  usecase "View Service Requirements" as UC7
  usecase "Upload Documents" as UC8
  usecase "Track Trámite" as UC9
}

package "Operator Actions" {
  usecase "View Assigned Reports" as UC10
  usecase "Update Report Status" as UC11
  usecase "Add Work Notes / Media" as UC12
}

package "Admin Actions" {
  usecase "Manage Operators" as UC13
  usecase "Assign Reports" as UC14
  usecase "View KPIs & Reports" as UC15
  usecase "Manage Services & Requirements" as UC16
}

' Associations
C --> UC1
C --> UC2
C --> UC3
C --> UC4
C --> UC5
C --> UC6
C --> UC7
C --> UC8
C --> UC9

O --> UC10
O --> UC11
O --> UC12

A --> UC13
A --> UC14
A --> UC15
A --> UC16

' Relationships between use cases
UC6 .> UC7 : includes
UC2 .> UC8 : requires <<upload documents>>
UC14 .> UC11 : includes

@enduml
